[Unit]
Description=olich_tutor Telegram bot (aiogram polling)
After=network-online.target olich-backend.service
Wants=network-online.target

[Service]
Type=simple
User=olich
Group=olich
WorkingDirectory=/opt/olich_tutor
EnvironmentFile=-/opt/olich_tutor/.env
ExecStart=/opt/olich_tutor/.venv/bin/python main.py
Restart=on-failure
RestartSec=5

[Install]
WantedBy=multi-user.target
