# Шаблон для копирования в корень репозитория на VPS: `/opt/olich_tutor/.env`
# Не коммитьте реальный `.env`.

# --- Telegram-бот (main.py) ---
TELEGRAM_TOKEN=
# Backend на той же машине:
BACKEND_BASE_URL=http://127.0.0.1:8000

# --- Backend (python -m backend), слушает BACKEND_HOST:BACKEND_PORT ---
BACKEND_HOST=127.0.0.1
BACKEND_PORT=8000

# --- LLM (OpenRouter) — только процесс backend ---
OPENROUTER_API_KEY=
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
LLM_MODEL=openai/gpt-4o-mini

# --- PostgreSQL (контейнер из deploy/docker-compose.postgres.yml: порт 5432 на 127.0.0.1) ---
# Пароль пользователя БД должен совпадать с POSTGRES_PASSWORD в deploy/.env.postgres
DATABASE_URL=postgresql+asyncpg://olich:ЗАМЕНИТЕ_ПАРОЛЬ@127.0.0.1:5432/olich_tutor

LOG_LEVEL=INFO
