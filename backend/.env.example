# Пример только для процесса HTTP API (`python -m backend` из корня репо или `make run-backend`).
# Полный шаблон монорепозитория (бот + backend) — в `../.env.example`. Скопируйте в корневой `.env`.
#
# Слушатель Uvicorn:
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000

# Логирование (`logging` в точке входа приложения):
LOG_LEVEL=INFO

# OpenRouter (OpenAI-совместимый клиент). Пустой ключ допустим при моках LLM в тестах.
OPENROUTER_API_KEY=
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
LLM_MODEL=openai/gpt-4o-mini

# PostgreSQL (локально через docker compose из корня репозитория: `make db-up`)
DATABASE_URL=postgresql+asyncpg://olich:olich_dev@127.0.0.1:5433/olich_tutor
