# Скопируйте в `.env` и заполните значения. Строки с `#` игнорируются загрузчиком.
#
# --- Telegram-бот (`make run`, корневой main.py) ---
# Без TELEGRAM_TOKEN бот не стартует. Диалог идёт через backend — поднимите API отдельно.
TELEGRAM_TOKEN=
# URL backend без завершающего слэша (процесс `make run-backend`).
BACKEND_BASE_URL=http://127.0.0.1:8000

# --- HTTP API backend (`make run-backend`, `python -m backend`) ---
# Процесс API не использует TELEGRAM_TOKEN. Хост и порт слушателя:
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000

# --- LLM (OpenRouter): для процесса backend ---
# Процесс бота не вызывает OpenRouter напрямую; ключ нужен сервису API для сценариев с LLM.
# Пустая строка допустима в тестах с моками LLM.
OPENROUTER_API_KEY=
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
LLM_MODEL=openai/gpt-4o-mini

# --- PostgreSQL (локально: `make db-up`, затем `make db-migrate`) ---
# Формат async-драйвера для SQLAlchemy: postgresql+asyncpg://…
DATABASE_URL=postgresql+asyncpg://olich:olich_dev@127.0.0.1:5433/olich_tutor

# --- Общее ---
LOG_LEVEL=INFO
